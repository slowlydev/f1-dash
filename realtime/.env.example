# ==============================================================================
# F1-DASH REALTIME SERVICE ENVIRONMENT VARIABLES
# ==============================================================================
# INSTRUCCIONES: Copia o renombre este archivo a `.env` en este directorio
# (o exporta estas variables en tu terminal) antes de ejecutar el servidor de Realtime.
# ==============================================================================

# Dirección y puerto donde el servidor de realtime escuchará las conexiones.
# Por defecto si no se define es 0.0.0.0:80, pero para desarrollo local usa un puerto alternativo libre.
ADDRESS=127.0.0.1:4000

# Orígenes CORS permitidos (URL de acceso al dashboard). Debe coincidir con la del cliente.
# Si hay múltiples, sepáralos con punto y coma (;).
ORIGIN=http://localhost:3000

# Nivel de registro (logging) para el servicio realtime (error, warn, info, debug, trace)
RUST_LOG=realtime=info

# (Opcional) URL para el simulador local de F1 en desarrollo.
# Si se descomenta y define, se usará la transmisión del simulador local en lugar de conectarse
# a la transmisión en vivo oficial de la F1.
# F1_DEV_URL=ws://127.0.0.1:8000/ws
