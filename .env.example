# ==============================================================================
# F1-DASH ROOT ENVIRONMENT VARIABLES
# ==============================================================================
# INSTRUCCIONES: Copia o renombre este archivo a `.env` en la raíz del proyecto
# antes de levantar la aplicación.
#
# Este archivo define las variables de entorno necesarias para levantar todos los
# componentes de la aplicación (dashboard, api, realtime y simulator) ya sea
# localmente o mediante Docker Compose.
# ==============================================================================

# --- CONFIGURACIÓN DEL DASHBOARD (Next.js) ---
# Puerto por defecto del dashboard en local
PORT=3000

# URL de conexión en tiempo real (SSE) a la que se conectará el cliente (navegador)
NEXT_PUBLIC_LIVE_URL=http://localhost:4000

# URL de la API a la que se conectará el dashboard para consultar datos históricos/sesiones
# - Si se levanta localmente sin Docker (usando Cargo/Rust): http://localhost:4001
# - Si se levanta con Docker Compose: http://localhost:4010
API_URL=http://localhost:4001


# --- CONFIGURACIÓN DE LA API (Rust Axum Service) ---
# Dirección y puerto donde el servicio de la API escuchará las peticiones
API_ADDRESS=127.0.0.1:4001

# Nivel de registro (logging) para la API
API_RUST_LOG=api=info

# Origen permitido para CORS (URL de acceso al dashboard)
API_ORIGIN=http://localhost:3000


# --- CONFIGURACIÓN DEL SERVICIO REALTIME (Rust Axum + SignalR Client) ---
# Dirección y puerto donde el servidor de tiempo real escuchará las peticiones
REALTIME_ADDRESS=127.0.0.1:4000

# Nivel de registro (logging) para el servicio Realtime
REALTIME_RUST_LOG=realtime=info

# Origen permitido para CORS (URL de acceso al dashboard)
REALTIME_ORIGIN=http://localhost:3000

# (Opcional) URL para el simulador local de F1 en desarrollo.
# Si se define, el servicio de realtime se conectará al simulador local en lugar de la API oficial de F1.
# F1_DEV_URL=ws://127.0.0.1:8000/ws


# --- CONFIGURACIÓN DEL SIMULADOR (Rust replay tool) ---
# Dirección y puerto donde el simulador de F1 simulará las tramas websocket en modo 'replay'
SIMULATOR_ADDRESS=127.0.0.1:8000
