# ==============================================================================
# F1-DASH API SERVICE ENVIRONMENT VARIABLES
# ==============================================================================
# INSTRUCCIONES: Copia o renombre este archivo a `.env` en este directorio
# (o exporta estas variables en tu terminal) antes de ejecutar el servidor de la API.
# ==============================================================================

# Dirección y puerto donde el servidor de la API escuchará las conexiones.
# Por defecto si no se define es 0.0.0.0:80, pero para desarrollo local usa un puerto alternativo libre.
ADDRESS=127.0.0.1:4001

# Orígenes CORS permitidos (URL de acceso al dashboard). Debe coincidir con la del cliente.
# Si hay múltiples, sepáralos con punto y coma (;).
ORIGIN=http://localhost:3000

# Nivel de registro (logging) para el servicio api (error, warn, info, debug, trace)
RUST_LOG=api=info
