# ==============================================================================
# F1-DASH DASHBOARD ENVIRONMENT VARIABLES
# ==============================================================================
# INSTRUCCIONES: Copia o renombre este archivo a `.env` o `.env.local`
# en este mismo directorio antes de levantar el dashboard en modo desarrollo.
# ==============================================================================

# --- runtime envs ---

# URL del servicio de Realtime (servidor SSE / Websockets) al cual el navegador del cliente se conectará
NEXT_PUBLIC_LIVE_URL=http://localhost:4000

# URL de la API REST para consultar información estática, programaciones, etc.
# - Si ejecutas la API localmente usando Cargo/Rust: http://localhost:4001
# - Si ejecutas la API usando Docker Compose por defecto: http://localhost:4010
API_URL=http://localhost:4001

# Deshabilitar iframe (opcional)
# DISABLE_IFRAME=0

# rybbit tracking script and id (opcional para analíticas)
# TRACKING_ID=
# TRACKING_URL=

# --- build envs ---

# SKIP_ENV_VALIDATION=1		# Omitir validación de variables en build (útil para Docker)
# NEXT_STANDALONE=1 			# Habilitar build standalone en Next.js (útil para Docker)
# NEXT_NO_COMPRESS=1 			# Deshabilitar compresión de Next.js (si se usa un proxy reverso)
